# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Agent-created git worktrees (transient; never commit)
.claude/worktrees/

# dependencies
/node_modules
/**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# stryker mutation testing (temp dirs, reports, logs)
.stryker-tmp
**/.stryker-tmp
**/reports/mutation
stryker.log
**/stryker.log

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts



.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Next.js
.next
out
# ...but `out` is also a hexagonal-architecture source dir (outbound ports), not build output.
!packages/**/out/

vite.config.*.timestamp*
vitest.config.*.timestamp*

# TanStack Start dev-server scratch dir
.tanstack/

# Secrets live only on disk; commit .env.example templates, never real env files.
.env
.env.*
!.env.example

# Brainstorming visual-companion sessions (superpowers plugin)
.superpowers/
