{
  "name": "jigswap-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=dev --projects=web",
    "dev:web": "nx dev web",
    "build": "nx run-many --target=build --all",
    "build:web": "nx build web",
    "start": "nx run-many --target=start --projects=web",
    "start:web": "nx start web",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "type-check": "nx run-many --target=type-check --all",
    "test": "nx run-many --target=test --all",
    "clean": "nx reset && rm -rf apps/*/dist apps/*/.next packages/*/dist",
    "format": "prettier --write . || true",
    "format:check": "prettier --check . || true",
    "graph": "nx graph",
    "affected": "nx affected",
    "arch:check": "depcruise --config .dependency-cruiser.cjs packages/domain/src",
    "mutation:domain": "nx run @jigswap/domain:mutation"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/next": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/web": "22.7.5",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "1.15.40",
    "@swc/helpers": "~0.5.23",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "jiti": "2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "nx": "22.7.5",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "nx": {
    "includedScripts": []
  }
}
