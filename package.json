{
  "name": "jigswap-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=dev --projects=web",
    "dev:web": "nx dev web",
    "build": "nx run-many --target=build --all",
    "build:web": "nx build web",
    "start": "nx run-many --target=start --projects=web",
    "start:web": "nx start web",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "type-check": "nx run-many --target=type-check --all",
    "test": "nx run-many --target=test --all",
    "clean": "nx reset && rm -rf apps/*/dist apps/*/.next packages/*/dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "graph": "nx graph",
    "affected": "nx affected",
    "arch:check": "depcruise --config .dependency-cruiser.cjs packages/domain/src",
    "mutation:domain": "nx run @jigswap/domain:mutation"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/next": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/web": "23.0.1",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "~0.5.23",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "jiti": "2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "nx": "23.0.1",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "nx": {
    "includedScripts": []
  }
}
