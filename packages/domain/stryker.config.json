{
  "$schema": "../../node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing for the pure @jigswap/domain package. Uses the vitest runner (vite.config.ts type-strips TS). coverageAnalysis perTest keeps re-runs fast by only re-running tests that cover a mutant. Thresholds are documented in MUTATION-TESTING.md. The break gate is 95: the measured baseline is ~98%, so CI stays green now while any regression below 95% breaks the build.",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!src/**/testing/**",
    "!src/**/index.ts",
    "!src/shared-kernel/branded-ids.ts",
    "!src/**/errors.ts"
  ],
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation-report.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "clearTextReporter": {
    "allowColor": true,
    "maxTestsToLog": 0,
    "reportMutants": false,
    "reportTests": false
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "thresholds": {
    "high": 98,
    "low": 95,
    "break": 95
  }
}
