# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://distinct-goshawk-54.clerk.accounts.dev

# Convex Backend
CONVEX_DEPLOYMENT=your_convex_deployment_url_here
NEXT_PUBLIC_CONVEX_URL=https://your_convex_deployment.convex.cloud

# Crowdin Localization
CROWDIN_PROJECT_ID=your_crowdin_project_id
CROWDIN_API_TOKEN=your_crowdin_api_token
NEXT_PUBLIC_CROWDIN_DISTRIBUTION_HASH=your_crowdin_distribution_hash

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Optional: Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
SENTRY_DSN=your_sentry_dsn_here

# Optional: File Upload (if implementing image uploads)
NEXT_PUBLIC_UPLOAD_ENDPOINT=your_upload_endpoint_here
UPLOAD_SECRET=your_upload_secret_here

# Optional: Knock (knock.app) — email/push notification delivery.
# Set these on the Convex deployment (npx convex env set). When unset, email/push
# notifications are dropped with a log; the in-app feed keeps working regardless.
KNOCK_API_KEY=sk_your_knock_secret_api_key
KNOCK_WORKFLOW_KEY=app-notification

# Optional: Image moderation for uploaded copy photos (library/moderatePhoto.ts).
# Set these on the Convex deployment (npx convex env set). The pipeline always re-encodes
# uploads to JPEG (stripping EXIF); classification is provider-pluggable and disabled-by-default.
#   MODERATION_PROVIDER:       "huggingface" (default) | "none" (always approve, no classification).
#   HF_MODERATION_TOKEN:       Hugging Face Inference API token (free tier). When UNSET, the
#                              huggingface provider FAILS OPEN — it approves every photo with a null
#                              score and logs a warning — so moderation is opt-in by setting a token.
#   MODERATION_NSFW_THRESHOLD: float in [0,1], default 0.85. An nsfw score >= threshold => rejected.
# Model: Falconsai/nsfw_image_detection. Any API/decode error also fails open (approve + log).
MODERATION_PROVIDER=huggingface
HF_MODERATION_TOKEN=hf_your_huggingface_inference_token
MODERATION_NSFW_THRESHOLD=0.85
