# Convex Backend (Vite exposes only VITE_-prefixed vars to the client)
# Same deployment as apps/web's NEXT_PUBLIC_CONVEX_URL.
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Clerk Authentication
# VITE_CLERK_PUBLISHABLE_KEY mirrors apps/web's NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Server-only, used by the Clerk server fn in __root.tsx (never exposed to the client).
CLERK_SECRET_KEY=sk_test_your_secret_key_here
